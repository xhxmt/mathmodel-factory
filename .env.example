# Copy to .env (gitignored) and fill in real values.

# OpenXLab MinerU API token — get one at https://mineru.net/apiManage/token
MINERU_TOKEN=

# Gemini API key for the google-antigravity SDK (run_paper.sh routes
# run_agy through scripts/agy_run.py → google.antigravity).  Get one at
# https://aistudio.google.com/apikey.  NOTE: this is separate from the
# OAuth token the legacy `agy` CLI uses at ~/.gemini/antigravity-cli/
# antigravity-oauth-token — the SDK does not accept OAuth, only API keys.
GEMINI_API_KEY=

# DeepSeek API key for the LLM judge evaluation harness
# (scripts/llm_judge_call.py). Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
