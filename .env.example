# Copy to .env (gitignored) and fill in real values.

# OpenXLab MinerU API token — get one at https://mineru.net/apiManage/token
MINERU_TOKEN=

# Gemini API key for the google-antigravity SDK (run_paper.sh routes
# run_agy through scripts/agy_run.py → google.antigravity).  Get one at
# https://aistudio.google.com/apikey.  NOTE: this is separate from the
# OAuth token the legacy `agy` CLI uses at ~/.gemini/antigravity-cli/
# antigravity-oauth-token — the SDK does not accept OAuth, only API keys.
# Also used by the "gemini" judge/API model-registry backend.
GEMINI_API_KEY=

# DeepSeek API key — used by the openai/deepseek model-registry backend
# (judge/review/eval steps) and the evaluation harness. Get one at
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Qwen / DashScope API key — only needed if you enable the example "qwen-max"
# model (an OpenAI-compatible host). Get one at
# https://dashscope.console.aliyun.com/apiKey . The registry entry uses
# base_url https://dashscope.aliyuncs.com/compatible-mode/v1 .
DASHSCOPE_API_KEY=
