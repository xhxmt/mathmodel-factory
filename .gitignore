# Local runtime state
/logs/
/ongoing/
/complete/
/papers/
/run_state/
/uploads/

# Web dashboard runtime config (edited via the UI, seeded by the backend).
# No secrets here — only model names + key_env VARIABLE names (keys live in .env).
/web/notes.json
/web/model_registry.json
/web/model_config.json
/web/auth.db
/web/auth.db-*

# External evaluation per-run outputs (regenerable; baseline_scores.md is kept)
/evaluation/results/

# Reference papers: PDFs and OCR output are large/binary, gitignored
# Only scripts and metadata are committed
/reference_papers/

# Project-local Python virtualenv (created by `python3 -m venv .venv`).
# Holds the google-antigravity SDK + transitive deps; run_paper.sh calls
# .venv/bin/python3 explicitly for scripts/agy_run.py.  Recreate via:
#   python3 -m venv .venv && .venv/bin/pip install google-antigravity
/.venv/

# Benchmark problems — fetched via scripts/fetch_benchmark.sh, not committed
/benchmark/

# Excellent-paper galleries — fetched via scripts/dxs_*.py, not committed
# (markdown analysis lives in docs/reference/)
/external/

# Local agent / brainstorming workspace (not part of the factory)
.superpowers/

/.worktrees/

# Python artifacts
__pycache__/
*.py[cod]
*$py.class

# Stata, LaTeX, and generated report outputs
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.pdf
*.smcl
*.synctex.gz
*.toc

# Local configuration and credentials
.env
.env.*
!.env.example
.claude/settings.local.json

# Document archives (organized historical docs)
/docs/sessions/
/web/docs/archive/
/archive/

# Web build artifacts and editor backups
web/**/*.tar.gz
*.backup

# Local scratch / one-off test output
/fibonacci_results.txt

# Editor and OS files
.DS_Store
.idea/
.vscode/
*.swp
*.swo
