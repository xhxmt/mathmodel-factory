# Paper Factory Web Dashboard Configuration
#
# Copy this file to .env and customize the values for your deployment.
# The .env file is gitignored and should never be committed.

# ════════════════════════════════════════════════════════════════
# Authentication
# ════════════════════════════════════════════════════════════════

# Admin password
# IMPORTANT: Change this in production!
ADMIN_PASSWORD=admin123

# JWT Secret Key (for signing authentication tokens)
# Generate a secure random string with: openssl rand -hex 32
# If not set, a random key will be generated at startup (sessions won't persist across restarts)
JWT_SECRET_KEY=

# JWT Token expiration time (in hours)
# Default: 24 hours
JWT_EXPIRATION_HOURS=24

# ════════════════════════════════════════════════════════════════
# Consultation Notifications (Optional)
# ════════════════════════════════════════════════════════════════

# Enable Telegram notifications for consultation requests
# Set to 1 to enable, 0 or unset to disable
CONSULT_TELEGRAM=0

# Telegram Bot Token (required if CONSULT_TELEGRAM=1)
# Get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (required if CONSULT_TELEGRAM=1)
# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# Enable email notifications (optional, future feature)
# CONSULT_EMAIL=your-email@example.com

# ════════════════════════════════════════════════════════════════
# Server Configuration
# ════════════════════════════════════════════════════════════════

# Backend API host and port
# Default: 0.0.0.0:8000 (listen on all interfaces)
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
# For development: http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ════════════════════════════════════════════════════════════════
# Factory Paths
# ════════════════════════════════════════════════════════════════

# Absolute path to the paper_factory repository root
# If not set, will be auto-detected from the script location
# FACTORY_ROOT=/home/tfisher/paper_factory

# ════════════════════════════════════════════════════════════════
# Logging
# ════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file paths (relative to FACTORY_ROOT/logs/)
LOG_FILE=api.log
ERROR_LOG_FILE=api.error.log
